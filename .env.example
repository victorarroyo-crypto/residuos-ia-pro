# ================================================================
# ResidusIA Pro - Variables de entorno
# ================================================================
# Copiar a .env y rellenar con tus valores reales:
#   cp .env.example .env
#
# NUNCA subir .env al repositorio (está en .gitignore)
# ================================================================

# ── SUPABASE ────────────────────────────────────────────────────
# Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...      # anon/public key (safe for frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJ...           # service_role key (SOLO backend/Edge Functions)

# ── ANTHROPIC (Claude) ─────────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── OPENAI (Embeddings) ────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── PIPELINE API ──────────────────────────────────────────────
# URL del servidor Python (FastAPI) que ejecuta el pipeline
# En desarrollo local: http://localhost:8000
# En produccion: URL del servicio desplegado (Railway, Fly.io, etc.)
PIPELINE_API_URL=http://localhost:8000

# ── FRONTEND URL (para CORS del pipeline) ─────────────────────
# En desarrollo local: http://localhost:3000
# En produccion: tu dominio de Vercel (ej: https://residusia.vercel.app)
FRONTEND_URL=http://localhost:3000

# ── GOOGLE DRIVE (OAuth2) ────────────────────────────────────
# Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
# Requiere habilitar la Google Drive API en el proyecto de Google Cloud
# Redirect URI autorizado: {FRONTEND_URL}/api/gdrive/callback
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── LANGSMITH (Observabilidad LangGraph - opcional) ─────────────
# https://smith.langchain.com/settings
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=residuos-ia-pro
LANGSMITH_API_KEY=lsv2_...
