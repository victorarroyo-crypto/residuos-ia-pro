# ================================================================
# ResidusIA Pro - Frontend (Next.js) - Variables de entorno
# ================================================================
# Copiar a .env.local y rellenar con tus valores reales:
#   cp .env.local.example .env.local
#
# Estas mismas variables hay que configurarlas en Vercel:
#   Vercel Dashboard > Settings > Environment Variables
# ================================================================

# -- SUPABASE (Dashboard > Project Settings > API) ----------------
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# -- PIPELINE API -------------------------------------------------
# URL del servidor Python (FastAPI) que ejecuta el pipeline
# Local: http://localhost:8000
# Produccion: la URL de tu servicio en Railway/Fly.io
PIPELINE_API_URL=http://localhost:8000

# Clave compartida para autenticar llamadas al backend Python.
# Debe coincidir con PIPELINE_API_KEY en Railway.
# Si esta vacia, la autenticacion se desactiva (solo desarrollo local).
PIPELINE_API_KEY=
